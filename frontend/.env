# =============================================================================
# API URL (optional override)
# =============================================================================
# Leave VITE_API_URL commented to auto-pick the API from the page you open:
#   - http://localhost:5173  → API http://localhost:5000
#   - http://192.168.x.x:5173 (phone on Wi‑Fi) → API http://192.168.x.x:5000
#   - http://YOUR_EC2_IP      → API http://YOUR_EC2_IP:5000
#
# Uncomment ONE line only when you need to force a fixed server (e.g. local UI → remote API):
# VITE_API_URL=http://localhost:5000
# VITE_API_URL=http://43.205.113.119:5000
#
# Optional: backend port when using auto mode (default 5000)
# VITE_API_PORT=5000
